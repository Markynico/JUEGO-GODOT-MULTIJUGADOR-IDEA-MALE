; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GODOT MULTIPLAYER (STEAM Y ENET) BASE"
run/main_scene="uid://db3c4gewtolrb"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="uid://bgjy42fvt4esl"

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/godotsteam/plugin.cfg")

[file_customization]

folder_colors={
"res://2d/": "green",
"res://3d/": "blue",
"res://escena_prototipos/": "red",
"res://escenas/": "orange"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"

[steam]

initialization/app_data/app_type=0
initialization/app_data/app_id=0
initialization/app_data/demo_id=0
initialization/app_data/playtest_id=0
initialization/app_data/tool_id=0
initialization/processes/initialize_on_startup=false
initialization/processes/embed_callbacks=false
multiplayer_peer/max_channels=4
